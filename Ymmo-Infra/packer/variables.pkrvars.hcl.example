# ──────────────────────────────────────────────
# Exemple de variables pour les Templates Packer
# ──────────────────────────────────────────────

# Connexion Proxmox
proxmox_api_url          = "https://votre-proxmox:8006/api2/json"
proxmox_api_token_id     = "packer@pve!votre-token"
proxmox_api_token_secret = "votre-secret-ici"
proxmox_node             = "pve"

# Chemins des ISO sur votre stockage Proxmox
iso_file          = "local:iso/debian-12.x.x-amd64-netinst.iso"
opnsense_iso_file = "local:iso/OPNsense-26.1-dvd-amd64.iso"

# Identifiants SSH pour le build Packer (Debian)
ssh_username = "packer"
ssh_password = "votre_mot_de_passe"

# Clés publiques SSH (injectées lors du build du template)
authorized_keys = [
  "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQC... votre-cle-publique-1"
]

# Configuration matérielle (Templates)
vm_id           = 9000
vm_cores        = 2
vm_memory       = 2048
vm_disk_size    = "20G"
vm_storage_pool = "local-lvm"
vm_bridge       = "vmbr0"

# IP de votre PC sur le tunnel WireGuard (pour servir le preseed Debian)
http_bind_address = "10.x.x.x"

# Credentials API OPNsense (générés avec : openssl rand -hex 40)
# Ces valeurs sont injectées dans config.xml pendant le build Packer
# et doivent être reportées telles quelles dans le vault Ansible
opnsense_api_key    = "votre-api-key-hex-80-chars"
opnsense_api_secret = "votre-api-secret-hex-80-chars"

# ──────────────────────────────────────────────────────────────────────────────
# Windows 11 25H2 — Template VM ID 9002
# ──────────────────────────────────────────────────────────────────────────────

# Chemins des ISO sur le datastore Proxmox "local"
# Uploader au préalable via : Datacenter > Storage > local > Upload
windows_iso_file = "local:iso/Win11_25H2_French_x64_v2.iso"
virtio_iso_file  = "local:iso/virtio-win-0.1.285.iso"

# Identifiant de la VM et dimensionnement matériel
windows_vm_id      = 9002
windows_vm_cores   = 4
windows_vm_memory  = 8192
windows_vm_disk_size = "64G"

# Pools de stockage Proxmox pour le firmware UEFI/OVMF et le vTPM 2.0
windows_efi_storage_pool = "local-lvm"
windows_tpm_storage_pool = "local-lvm"

# ISO Autounattend PRÉ-CONSTRUITE, uploadée sur Proxmox comme les autres ISOs.
# La générer une fois depuis le dossier packer/ :
#   xorriso -as mkisofs -J -r -V AUTOUNATTEND -o autounattend.iso autounattend/
# puis l'uploader (UI Proxmox > Storage > ISO Images) et indiquer son chemin ici.
autounattend_iso_file = "Backup-Node1:iso/autounattend.iso"

# Credentials WinRM utilisés pendant le build Packer
# IMPORTANT : winrm_password doit correspondre exactement au mot de passe
# encodé dans packer/autounattend/Autounattend.xml (champ <Password> du
# compte "packer"). Ce compte est re-déclaré dans l'unattend Sysprep :
# il reste le compte d'administration local des clones (utilisé par Ansible).
winrm_username = "packer"
winrm_password = "Packer-Build-2026!"

# Clé publique SSH autorisée pour les administrateurs des clones Windows.
# Les clones sont pilotés par Ansible via OpenSSH (ProxyJump bastion) ;
# mettre ici la même clé que pour les VMs Debian. Vide = mot de passe seul.
windows_ssh_authorized_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQC... votre-cle-publique-1"
